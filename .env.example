# ─────────────────────────────────────────────────────────────────────────────
# TraderPro Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production          # development | production
PORT=3000

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING

# Comma-separated list of allowed CORS origins (leave blank to allow all)
# Example: https://traderpro.app,https://www.traderpro.app
ALLOWED_ORIGINS=

# ── Optional: OpenRouter (LLM Trade Engine) ───────────────────────────────────
# Get free key at https://openrouter.ai
OPENROUTER_API_KEY=

# ── Optional: Custom DB path (defaults to ./trader_portal.db) ────────────────
DB_PATH=

# ── Optional: ML service URL (defaults to http://127.0.0.1:5001) ─────────────
ML_SERVICE_URL=http://127.0.0.1:5001

# ── Optional: AutoTrade service URL (defaults to http://127.0.0.1:5002) ──────
AUTOTRADE_SERVICE_URL=http://127.0.0.1:5002
